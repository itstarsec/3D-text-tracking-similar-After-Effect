[
  {
    "start": "00:00:03.264",
    "end": "00:00:06.190",
    "text": "I THOUGHT\nI SAW YOUR\nFACE TODAY"
  },
  {
    "start": "00:00:06.200",
    "end": "00:00:10.150",
    "text": "BUT I JUST\nTURNED MY\nHEAD AWAY"
  },
  {
    "start": "00:00:10.160",
    "end": "00:00:13.510",
    "text": "YOUR FACE\nAGAINST\nTHE TREES"
  },
  {
    "start": "00:00:13.520",
    "end": "00:00:15.750",
    "text": "BUT I JUST SEE\nTHE MEMORIES\nAS THEY COME"
  },
  {
    "start": "00:00:15.760",
    "end": "00:00:18.950",
    "text": "AS THEY\nCOME"
  },
  {
    "start": "00:00:18.960",
    "end": "00:00:25.030",
    "text": "AND I COULDN'T\nHELP BUT FALL\nIN LOVE AGAIN"
  },
  {
    "start": "00:00:25.040",
    "end": "00:00:31.710",
    "text": "NO, I COULDN'T\nHELP BUT FALL\nIN LOVE AGAIN"
  },
  {
    "start": "00:00:35.360",
    "end": "00:00:37.230",
    "text": "I SAW IT\nGLITTER\nAS I GREW"
  },
  {
    "start": "00:00:37.240",
    "end": "00:00:40.070",
    "text": "AND LOVED IT\nWHILE I\nNEVER KNEW"
  },
  {
    "start": "00:00:40.080",
    "end": "00:00:41.470",
    "text": "I THOUGHT\nTHIS PLACE WAS\nHEAVEN-SENT"
  },
  {
    "start": "00:00:41.480",
    "end": "00:00:46.950",
    "text": "BUT NOW IT'S JUST\nA MONUMENT\nIN MY MIND"
  },
  {
    "start": "00:00:46.960",
    "end": "00:00:50.070",
    "text": "IN MY\nMIND"
  },
  {
    "start": "00:00:50.080",
    "end": "00:00:56.150",
    "text": "AND I COULDN'T\nHELP BUT FALL\nIN LOVE AGAIN"
  },
  {
    "start": "00:00:56.160",
    "end": "00:01:00.250",
    "text": "NO, I COULDN'T\nHELP BUT FALL\nIN LOVE AGAIN"
  },
  {
    "start": "00:01:05.430",
    "end": "00:01:07.790",
    "text": "THE CARS\nAND FREEWAYS\nIMPLORE ME"
  },
  {
    "start": "00:01:07.800",
    "end": "00:01:08.765",
    "text": "TO STAY\nAWAY"
  },
  {
    "start": "00:01:08.775",
    "end": "00:01:09.030",
    "text": "OUT OF\nTHIS PLACE"
  },
  {
    "start": "00:01:09.040",
    "end": "00:01:12.310",
    "text": "MY MOTHER SAID,\nJUST KEEP\nYOUR HEAD"
  },
  {
    "start": "00:01:12.320",
    "end": "00:01:15.970",
    "text": "AND PLAY IT\nAS IT\nLAYS"
  },
  {
    "start": "00:01:50.686",
    "end": "00:01:52.030",
    "text": "THE CARS\nAND FREEWAYS\nIMPLORE ME"
  },
  {
    "start": "00:01:52.040",
    "end": "00:01:55.271",
    "text": "TO STAY AWAY\nOUT OF\nTHIS PLACE"
  },
  {
    "start": "00:01:55.281",
    "end": "00:01:58.790",
    "text": "MY MOTHER SAID,\nJUST KEEP\nYOUR HEAD"
  },
  {
    "start": "00:01:58.800",
    "end": "00:02:02.870",
    "text": "AND PLAY IT\nAS IT\nLAYS"
  },
  {
    "start": "00:02:06.406",
    "end": "00:02:09.350",
    "text": "I SOMEHOW SEE\nWHAT'S BEAUTIFUL\nIN THINGS"
  },
  {
    "start": "00:02:09.360",
    "end": "00:02:10.230",
    "text": "THAT ARE\nEPHEMERAL"
  },
  {
    "start": "00:02:10.240",
    "end": "00:02:12.350",
    "text": "I'M MY\nONLY FRIEND\nOF MINE"
  },
  {
    "start": "00:02:12.360",
    "end": "00:02:17.470",
    "text": "LOVE IS JUST\nA PIECE OF TIME\nIN THE WORLD"
  },
  {
    "start": "00:02:17.480",
    "end": "00:02:20.510",
    "text": "IN THE\nWORLD"
  },
  {
    "start": "00:02:20.520",
    "end": "00:02:26.390",
    "text": "AND I COULDN'T\nHELP BUT FALL\nIN LOVE AGAIN"
  },
  {
